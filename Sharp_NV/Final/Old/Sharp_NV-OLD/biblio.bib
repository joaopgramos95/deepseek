@article{CorreiaKinoshita,
title = {Global well-posedness and scattering for the 2D modified {Z}akharov-{K}uznetsov equation},
journal = {Journal de Mathématiques Pures et Appliquées},
volume = {211},
pages = {103884},
year = {2026},
issn = {0021-7824},
doi = {https://doi.org/10.1016/j.matpur.2026.103884},
url = {https://www.sciencedirect.com/science/article/pii/S0021782426000309},
author = {Simão Correia and Shinya Kinoshita},
keywords = {Modified Zakharov-Kuznetsov, Global well-posedness, Scattering},
abstract = {We consider the Cauchy problem associated with the modified Zakharov-Kuznetsov equation over R2. Taking into consideration the associated dispersive effects, we introduce, for s,a≥0, a two-parameter space Hs,a(R2), which scales as the classic Hs spaces. In this new class, we prove local well-posedness for s+a≥1/4, 0<a<1/4, and global well-posedness and scattering for small data in the case s=0,a=1/4. These results are shown to be sharp in the sense of C3-flows.
Résumé
Nous considérons le problème de Cauchy associé à l'équation de Zakharov-Kuznetsov modifiée sur R2. En tenant compte des effets dispersifs associés, nous introduisons, pour s,a≥0, un espace à deux paramètres Hs,a(R2), qui se comporte comme les espaces Hs classiques. Dans cette nouvelle classe, nous démontrons que le problème est bien-posé localement pour s+a≥1/4 0<a<1/4, et globalement bien-posé avec scattering pour de données petites dans le cas s=0,a=1/4. Ces résultats sont optimaux au sens des flots C3.}
}


