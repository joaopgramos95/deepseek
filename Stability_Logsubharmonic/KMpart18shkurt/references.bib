@article{CorderoGrochenig,
title = {Time–Frequency analysis of localization operators},
journal = {Journal of Functional Analysis},
volume = {205},
number = {1},
pages = {107-131},
year = {2003},
%issn = {0022-1236},
%doi = {https://doi.org/10.1016/S0022-1236(03)00166-6},
%url = {https://www.sciencedirect.com/science/article/pii/S0022123603001666},
author = {Elena Cordero and Karlheinz Gröchenig},
%keywords = {Localization operator, Modulation space, Weyl calculus, Convolution relations, Wigner distribution, Short-time Fourier transform, Schatten class, Feichtinger's algebra},
%abstract = {We study a class of pseudodifferential operators known as time–frequency localization operators, Anti-Wick operators, Gabor–Toeplitz operators or wave packets. Given a symbol a and two windows ϕ1,ϕ2, we investigate the multilinear mapping from (a,ϕ1,ϕ2)∈S′(R2d)×S(Rd)×S(Rd) to the localization operator Aaϕ1,ϕ2 and we give sufficient and necessary conditions for Aaϕ1,ϕ2 to be bounded or to belong to a Schatten class. Our results are formulated in terms of time–frequency analysis, in particular we use modulation spaces as appropriate classes for symbols and windows.}
}

