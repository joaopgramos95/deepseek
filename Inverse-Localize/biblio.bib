@article{Takagi1,
	author = {Takagi, Shin},
	title = "{Quantum Dynamics and Non-Inertial Frames of Reference. I: Generality}",
	journal = {Progress of Theoretical Physics},
	volume = {85},
	number = {3},
	pages = {463-479},
	year = {1991},
	month = {03},
	abstract = "{The general framework of a time-dependent scale transformation as applied to non-relativistic time-dependent Schrödinger equations is described. The nature of the transformation is clarified by comparing it with a time-dependent translation and rotation. Particular attention is paid to the associated gauge transformation and the resulting harmonic inertial force. Corresponding classical results are also displayed. This work intends to pave the way for various applications to be presented in the subsequent papers of this series.}",
	issn = {0033-068X},
	doi = {10.1143/ptp/85.3.463},
	url = {https://doi.org/10.1143/ptp/85.3.463},
	eprint = {https://academic.oup.com/ptp/article-pdf/85/3/463/5310646/85-3-463.pdf},
}

@article{Takagi2,
	author = {Takagi, Shin},
	title = "{Quantum Dynamics and Non-Inertial Frames of References. II: Harmonic Oscillators}",
	journal = {Progress of Theoretical Physics},
	volume = {85},
	number = {4},
	pages = {723-742},
	year = {1991},
	month = {04},
	abstract = "{Physical consequences of the theorem of equivalence among harmonic oscillators of different frequencies, including a free particle as a special case, are explored. A new pictorial way of understanding time-dependent coherent states and squeezed states are presented and contrasted with the standard view. Three-dimensional spherical analogues of squeezed coherent states are constructed. It is also shown as a corollary of the theorem that a free wave packet which coincides initially with any one of the eigenfunctions of a harmonic oscillator maintains its shape, that is, the probability density of position does not change apart from a time-dependent scaling of spatial coordinates. Most of the results are derived without use of any sophisticated techniques but with the knowledge of free wave packets alone.}",
	issn = {0033-068X},
	doi = {10.1143/ptp/85.4.723},
	url = {https://doi.org/10.1143/ptp/85.4.723},
	eprint = {https://academic.oup.com/ptp/article-pdf/85/4/723/6866759/85-4-723.pdf},
}

@article{CassanoFanelli2016,
	title = {Gaussian decay of harmonic oscillators and related models},
	journal = {Journal of Mathematical Analysis and Applications},
	volume = {456},
	number = {1},
	pages = {214-228},
	year = {2017},
	issn = {0022-247X},
	doi = {https://doi.org/10.1016/j.jmaa.2017.06.067},
	url = {https://www.sciencedirect.com/science/article/pii/S0022247X17306297},
	author = {B. Cassano and L. Fanelli},
	keywords = {Schrödinger equation, Uniform electric potentials, Uniform magnetic potentials, Harmonic oscillator, Unique continuation, Uncertainty principle},
	abstract = {We prove that the decay of the eigenfunctions of harmonic oscillators, uniform electric or magnetic fields is not stable under 0-order complex perturbations, even if bounded, of these Hamiltonians, in the sense that we can produce solutions to the evolutionary Schrödinger flows associated to the Hamiltonians, with a stronger Gaussian decay at two distinct times. We then characterize, in a quantitative way, the sharpest possible Gaussian decay of solutions as a function of the oscillation frequency or the strength of the field, depending on the Hamiltonian which is considered. This is connected to the Hardy's Uncertainty Principle for free Schrödinger evolutions.}
}

