@article{BarceloBiagioFanelli2021,
	title = {Mass propagation for electromagnetic Schrödinger evolutions},
	journal = {Nonlinear Analysis},
	volume = {217},
	pages = {112734},
	year = {2022},
	issn = {0362-546X},
